# Job Search Dashboard — environment variables
# Copy to .env and fill in your values, or export directly in your shell profile.

# ── Dashboard ──────────────────────────────────────────────────────────────────

# Port the dashboard runs on (default: 3000)
DASHBOARD_PORT=3000

# ── USAJobs API ────────────────────────────────────────────────────────────────
# Required only if you want to search federal government positions.
# Register for a free key at: developer.usajobs.gov/apirequest/
# Add these to your shell profile (~/.zshrc or ~/.bashrc), NOT to .env —
# they are read by the CLI tools running on your host machine, not by Docker.

# USAJOBS_API_KEY=your-key-here
# USAJOBS_EMAIL=you@example.com
